<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.sistemamatricula.Controlador.RegistroUsuarioControlador">

   <children>

      <VBox alignment="CENTER" spacing="25"
            AnchorPane.topAnchor="20"
            AnchorPane.leftAnchor="0"
            AnchorPane.rightAnchor="0">

         <!-- Título -->
         <Label text="Registro de Usuario"
                style="-fx-font-size: 22px; -fx-font-weight: bold;" />

         <!-- Formulario -->
         <GridPane alignment="CENTER" hgap="15" vgap="15">

            <Label text="DNI:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="txt_dni" prefWidth="220"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Correo:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="txt_correo" prefWidth="220"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Contraseña:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <PasswordField fx:id="txt_contrasena" prefWidth="220"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>

         </GridPane>

         <!-- Tipo de usuario -->
         <HBox alignment="CENTER" spacing="30">
            <RadioButton text="Estudiante">
               <toggleGroup>
                  <ToggleGroup fx:id="Grupo1"/>
               </toggleGroup>
            </RadioButton>

            <RadioButton text="Profesor"
                         toggleGroup="$Grupo1"/>
         </HBox>

         <!-- Botones -->
         <HBox alignment="CENTER" spacing="40">
            <Button fx:id="registrarUsuario"
                    text="Ingresar Datos"
                    onAction="#registrarDatos"
                    prefWidth="140"/>

            <Button text="Atrás"
                    onAction="#retroceder"
                    prefWidth="120"/>
         </HBox>

      </VBox>

   </children>

</AnchorPane>